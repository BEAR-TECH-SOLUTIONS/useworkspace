# Self-hosted usework.space environment template. The install.sh script
# copies this to .env, fills the secrets it can generate locally
# (APP_KEY, REVERB_APP_SECRET, POSTGRES_PASSWORD, LICENSE_INSTANCE_ID)
# and prompts for the rest.

# ─── Self-hosted identity / licensing ──────────────────────────────
# TC_DOMAIN must appear BEFORE any line that interpolates it (e.g.
# APP_URL below). Docker Compose parses .env top-to-bottom and
# interpolates ${VAR} references inline — a forward reference
# resolves to an empty string, the Caddyfile's `{$TC_DOMAIN}` site
# directive then binds to empty hostname, and TLS provisioning fails
# silently.
TC_EDITION=self_hosted
TC_DOMAIN=
TC_VERSION=latest
LICENSE_TOKEN=
LICENSE_INSTANCE_ID=
LICENSE_PHONE_HOME_URL=https://api.usework.space/api/v1/licenses/verify

# Per-install Ed25519 attestation keypair. Generated locally by
# install.sh and never sent off-box (the public half is uploaded once
# during the license claim, the cloud signs it into LICENSE_ATTESTATION
# below). The /api/v1/server/attest endpoint signs desktop-client
# nonces with this key so clients can prove they're talking to this
# specific install — not a phishing copy of the public attestation.
# Both values are base64-encoded raw 32-byte keys.
LICENSE_INSTANCE_PRIVATE_KEY=
LICENSE_INSTANCE_PUBLIC_KEY=

# Cloud-signed attestation envelope binding this install's license_id
# and instance_public_key. Served verbatim from /api/v1/server/attest.
# Distinct from LICENSE_TOKEN — this is the *public* identity proof,
# safe to expose; LICENSE_TOKEN is the secret used to phone-home.
LICENSE_ATTESTATION=

APP_NAME=usework.space
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://${TC_DOMAIN}

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=usework
DB_USERNAME=usework
DB_PASSWORD=

POSTGRES_DB=usework
POSTGRES_USER=usework
POSTGRES_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=usework
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Internal docker hostname — the `app`, `worker`, and `scheduler`
# containers publish broadcast events directly to this service over
# the compose network. The desktop client connects via wss:// to the
# public Caddy hostname; Caddy proxies /app/* + /apps/* + /broadcasting/auth
# down to reverb:8080 in plain HTTP, so TLS only lives at the edge.
REVERB_HOST=reverb
REVERB_PORT=8080
# MUST stay `http` — Reverb on port 8080 speaks plain HTTP. Setting
# this to `https` makes the server-side Pusher SDK try to TLS-handshake
# against a non-TLS port and hang for 10s before Broadcasting throws
# (cURL error 28). The CLIENT scheme is wss:// and is independent —
# it lives in the desktop client's own build env, not here.
REVERB_SCHEME=http

# Optional toggles. Set to false to fence on-prem users from creating
# share links / posting feedback to the central backend.
SELFHOST_SHARE_LINKS_ENABLED=true
SELFHOST_FEEDBACK_REMOTE=true
