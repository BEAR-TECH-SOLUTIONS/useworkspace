# Self-hosted usework.space environment template. The install.sh script
# copies this to .env, fills the secrets it can generate locally
# (APP_KEY, REVERB_APP_SECRET, POSTGRES_PASSWORD, LICENSE_INSTANCE_ID)
# and prompts for the rest.

# ─── Self-hosted identity / licensing ──────────────────────────────
# TC_DOMAIN must appear BEFORE any line that interpolates it (e.g.
# APP_URL below). Docker Compose parses .env top-to-bottom and
# interpolates ${VAR} references inline — a forward reference
# resolves to an empty string, the Caddyfile's `{$TC_DOMAIN}` site
# directive then binds to empty hostname, and TLS provisioning fails
# silently.
TC_EDITION=self_hosted
TC_DOMAIN=
TC_VERSION=latest
LICENSE_TOKEN=
LICENSE_INSTANCE_ID=
LICENSE_PHONE_HOME_URL=https://api.usework.space/api/v1/licenses/verify

APP_NAME=usework.space
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://${TC_DOMAIN}

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=usework
DB_USERNAME=usework
DB_PASSWORD=

POSTGRES_DB=usework
POSTGRES_USER=usework
POSTGRES_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=usework
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=https

# Optional toggles. Set to false to fence on-prem users from creating
# share links / posting feedback to the central backend.
SELFHOST_SHARE_LINKS_ENABLED=true
SELFHOST_FEEDBACK_REMOTE=true
